# --- Database ---
# SQLite default for zero-config local dev. Swap for Postgres in prod:
# DATABASE_URL=postgresql+psycopg://user:pass@localhost:5432/nagarik
DATABASE_URL=sqlite:///./nagarik.db

# --- Object storage ---
# Local fs for dev; S3-compatible URL in prod (s3://bucket/prefix)
STORAGE_BACKEND=local
STORAGE_LOCAL_PATH=../data/storage

# --- LLM ---
# Leave unset to use the deterministic rule-based fallback.
# ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# --- Admin ---
ADMIN_TOKEN=dev-admin-token-change-me

# --- Scheduler ---
# Set to "false" in tests / one-shot runs
ENABLE_SCHEDULER=true
INGESTION_CRON_HOUR=0
INGESTION_CRON_MINUTE=0
INGESTION_CRON_TZ=Asia/Kolkata

# --- App ---
ENV=development
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000
